{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/activate.sh\"; exit 0",
            "commandWindows": "bash \"%CLAUDE_PLUGIN_ROOT%\\hooks\\activate.sh\"",
            "timeout": 5,
            "statusMessage": "Loading upward-mobility operating discipline..."
          }
        ]
      }
    ]
  }
}
